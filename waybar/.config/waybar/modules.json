//
{
  // Workspaces
  "hyprland/workspaces": {
    "active-only": false,
    "all-outputs": true,
    "disable-scroll": false,
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "format": "{windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "",
    "window-rewrite": {
      "class<librewolf>": "",
      "class<discord>": "󰙯",
      "class<spotify>": "",
      "class<VirtualBox Manager>": "󰆧",
      "class<VirtualBox Machine>": "󰆧",
      "class<kitty>": "",
      "class<obsidian>": "󰭺",
      "class<code-oss>": "",
      "class<thunar>": "",
      "class<steam>": "",
      "class<mpv>": "",
      "class<obs>": ""
    },
    "tooltip": false,
    "sort-by-number": true
  },
  // Taskbar
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "kitty"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },
  "custom/streamer": {
    "format": "",
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/streamer_mode.sh"
  },
  // Hyprland Window
  "hyprland/window": {
    "max-length": 60,
    "format": "{class}",
    "tooltip": false,
    "seperate-outputs": true,
    "markup": true,
    "rewrite": {
      "libreWolf": "<span size='150%' color='#3DAEE9'></span>",
      "discord": "<span size='150%' color='#5865F2'>󰙯</span>",
      "spotify": "<span size='150%' color='#1DB954'></span>",
      "VirtualBox Manager": "<span size='150%' color='#F48024'>󰆧</span>",
      "VirtualBox Machine": "<span size='150%' color='#00FF00'>󰆧</span>",
      "kitty": "<span size='150%' color='#00FFFF'></span>",
      "obsidian": "<span size='150%' color='#7C3AED'>󰂺</span>",
      "thunar": "<span size='150%' color='#4A90D9'></span>",
      "code-oss": "<span size='150%' color='#007ACC'></span>",
      "^$": "<span size='150%' color='#1793D1'></span>"
    },
    "separate-outputs": true
  },
  // Waybar Themes
  "custom/waybarthemes": {
    "format": "",
    "on-click": "~/.config/waybar/themeswitcher.sh",
    "tooltip-format": "Select a waybar theme"
  },
  // Rofi Application Launcher
  "custom/appmenu": {
    // START APPS LABEL
    "format": "Apps",
    // END APPS LABEL
    "on-click": "~/.config/hypr/scripts/launcher.sh",
    "on-click-right": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },
  // Rofi Application Launcher
  "custom/appmenuicon": {
    "format": "",
    "on-click": "sleep 0.2;rofi -show drun -replace",
    "on-click-right": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },
  // Hyprshade
  "custom/hyprshade": {
    "format": "",
    "tooltip-format": "Toggle Screen Shader",
    "on-click": "sleep 0.5; ~/.config/hypr/scripts/hyprshade.sh",
    "on-click-right": "sleep 0.5; ~/.config/hypr/scripts/hyprshade.sh rofi",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // System tray
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  // Clock
  "custom/clock": {
    "return-type": "json",
    "interval": 1,
    "exec": "~/.config/waybar/scripts/clock.sh",
    "exec-if": "[ ! -f /tmp/waybar_streamer_mode ]"
  },
  "custom/updates": {
    "exec": "/home/infinit3i/.config/waybar/scripts/pkg_status.sh",
    "interval": 600,
    "return-type": "json",
    "on-click": "kitty -e bash -c 'yay -Syyu; echo; read -n1 -s -r -p \"Press any key to close\"'; pkill -SIGRTMIN+8 waybar",
    "signal": 8,
    "exec-if": "[ ! -f /tmp/waybar_streamer_mode ]"
  },
  "custom/gpu": {
    "format": "G {}",
    "exec": "~/.config/waybar/scripts/gpu_util.sh",
    "interval": 5,
    "return-type": "json"
  },
  "custom/system": {
    "format": "",
    "tooltip": false,
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  "cpu": {
    "format": "C {usage}% ",
    "on-click": "",
    "interval": 5,
    "on-scroll-up": "true",
    "on-scroll-down": "true",
    "states": {
      "normal": 0,
      "warning": 60,
      "critical": 85
    }
  },
  "memory": {
    "format": "M {}% ",
    "interval": 5,
    "on-click": "kitty -e htop",
    "on-scroll-up": "true",
    "on-scroll-down": "true",
    "states": {
      "normal": 0,
      "warning": 60,
      "critical": 85
    }
  },
  "disk": {
    "interval": 180,
    "format": "D {percentage_used}% ",
    "path": "/",
    "on-click": "",
    "on-scroll-up": "true",
    "on-scroll-down": "true",
    "states": {
      "normal": 0,
      "warning": 60,
      "critical": 85
    }
  },
  "group/tools": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 200,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/hyprshade"
    ]
  },
  "group/links": {
    "orientation": "horizontal",
    "modules": [
      "custom/chatgpt",
      "custom/empty"
    ]
  },
  // Group Settings
  "group/settings": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 200,
      "children-class": "not-memory",
      "transition-left-to-right": true
    },
    "modules": [
      "custom/settings",
      "custom/waybarthemes",
      "custom/wallpaper"
    ]
  },
  // Network
  "custom/afw": {
    "exec": "~/.config/waybar/scripts/afw_status.sh",
    "exec-if": "[ ! -f /tmp/waybar_streamer_mode ]",
    "interval": 10,
    "return-type": "json",
    "on-click": "kitty -e bash -c 'sudo afw status; echo; sudo afw pending; read -rp \"Press Enter to close\"'"
  },
  "custom/external_ip": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/external_ip.sh",
    "exec-if": "[ ! -f /tmp/waybar_streamer_mode ]",
    "interval": 1800
  },
  "custom/est": {
    "interval": 10,
    "exec": "ss -t state established | wc -l",
    "exec-if": "[ ! -f /tmp/waybar_streamer_mode ]",
    "format": "EST {}",
    "on-click": "kitty sh -lc 'watch -n 1 --no-title \"ss -t state established -p -n | sed \\\"s/\\t/ /g\\\"\"'"
  },
  "network": {
    "format": "{ifname}",
    "format-wifi": "  {signalStrength}%",
    "format-ethernet": "  {ifname}",
    "format-disconnected": "Disconnected ⚠",
    "tooltip-format": " {ifname} via {gwaddri}",
    "tooltip-format-wifi": "  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": " {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "",
    "on-click-right": "",
  },
  "custom/clamav": {
    "exec": "~/.config/waybar/scripts/clamav.sh",
    "exec-if": "[ ! -f /tmp/waybar_streamer_mode ]",
    "interval": 180,
    "format": "{}",
    "tooltip": false,
    "on-click": "kitty -e ~/.config/waybar/scripts/clamav_view.sh"
  },
  "group/network": {
    "orientation": "inherit",
    "exec-if": "[ ! -f /tmp/waybar_streamer_mode ]",
    "modules": [
      "network",
      "custom/external_ip",
      "custom/est",
      "custom/afw",
      "custom/clamav"
    ]
  },
  // Pulseaudio
  "pulseaudio": {
    "scroll-step": 1, // %, can be a float
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{volume}% {icon} {format_source}",
    "format-bluetooth-muted": " {icon} {format_source}",
    "format-muted": " {format_source}",
    "format-source": "{volume}% ",
    "format-source-muted": "",
    "on-click": "pavucontrol"
  },
  // Bluetooth
  "bluetooth": {
    "format": " {status}",
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "sleep 0.1 && ~/.config/ml4w/settings/bluetooth.sh",
    "tooltip-format-connected": "Connected devices: {num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t| Battery life: {device_battery_percentage}%",
    "format-no-controller": ""
  },
  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },
  "custom/dnd": {
    "exec": "~/.config/waybar/scripts/dnd.sh",
    "exec-if": "[ ! -f /tmp/waybar_streamer_mode ]",
    "interval": 5,
    "return-type": "json",
    "on-click": "~/.config/waybar/scripts/dnd_toggle.sh"
  },
  // backlight:
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "",
      "",
      "",
      "",
      "",
      "",
      "",
      "",
      "",
      "",
      "",
      "",
      "",
      "",
      ""
    ],
    "scroll-step": 1
  }
}
