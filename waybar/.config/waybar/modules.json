{
  // Workspaces
  "hyprland/workspaces": {
    "active-only": false,
    "all-outputs": false,
    "disable-scroll": false,
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "format": "{icon}",
    "tooltip": false,
    "sort-by-number": true,
    "persistent-workspaces": {
      "DP-3": [
        1,
        2,
        3
      ],
      "DP-4": [
        4,
        5,
        6
      ],
      "HDMI-A-5": [
        7,
        8,
        9
      ]
    },
    "format-icons": {
      "default": "яДС",
      "active": "яЖТ",
      "urgent": "яБк"
    }
  },
  // Taskbar
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "kitty"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },
  // Hyprland Window
   "hyprland/window": {
    "max-length": 60,
    "format": "{class}",
    "seperate-outputs": true,
    "markup": true,
    "rewrite": {
	"libreWolf": "<span size='150%' color='#3DAEE9'>яЙй</span>",
    	"discord": "<span size='150%' color='#5865F2'>ґ░Щп</span>",
    	"spotify": "<span size='150%' color='#1DB954'>яЖ╝</span>",
    	"VirtualBox Manager": "<span size='150%' color='#F48024'>ґ░Жз</span>",
    	"VirtualBox Machine": "<span size='150%' color='#00FF00'>ґ░Жз</span>",
    	"kitty": "<span size='150%' color='#00FFFF'>юЮХ</span>",
      "code-oss": "<span size='150%' color='#007ACC'>юЮХ</span>",
      "^$": "<span size='150%' color='#1793D1'>яМГ</span>"
    },
    "separate-outputs": true
  },
  // Waybar Themes
  "custom/waybarthemes": {
    "format": "яЕБ",
    "on-click": "~/.config/waybar/themeswitcher.sh",
    "tooltip-format": "Select a waybar theme"
  },
  // Rofi Application Launcher
  "custom/appmenu": {
    // START APPS LABEL
    "format": "Apps",
    // END APPS LABEL
    "on-click": "~/.config/hypr/scripts/launcher.sh",
    "on-click-right": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },
  // Rofi Application Launcher
  "custom/appmenuicon": {
    "format": "яД╡",
    "on-click": "sleep 0.2;rofi -show drun -replace",
    "on-click-right": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },
  // Hyprshade
  "custom/hyprshade": {
    "format": "юУЬ",
    "tooltip-format": "Toggle Screen Shader",
    "on-click": "sleep 0.5; ~/.config/hypr/scripts/hyprshade.sh",
    "on-click-right": "sleep 0.5; ~/.config/hypr/scripts/hyprshade.sh rofi",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Hypridle inhibitor
  "custom/hypridle": {
    "format": "яАг",
    "return-type": "json",
    "escape": true,
    "exec-on-event": true,
    "interval": 60,
    "exec": "~/.config/hypr/scripts/hypridle.sh status",
    "on-click": "~/.config/hypr/scripts/hypridle.sh toggle",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "яАг",
      "unlocked": "яВЬ"
    },
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // System tray
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  // Clock
  "clock": {
    "format": "{:%H:%M %a}",
    "on-click": "",
    "timezone": "",
    "tooltip": false
  },
  "custom/updates": {
    "exec": "/home/infinit3i/.config/waybar/scripts/pkg_status.sh",
    "interval": 1800,
    "return-type": "json",
    "on-click": "kitty -e bash -c 'sudo pacman -Syyu; echo; read -n1 -s -r -p \"Press any key to close\"'"
  },
  "custom/gpu": {
    "format": "G {}/",
    "exec": "~/.config/waybar/scripts/gpu_util.sh",
    "interval": 2,
    "return-type": "json"
  },
  // System
  "custom/system": {
    "format": "яЛЫ",
    "tooltip": false,
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // CPU
  "cpu": {
    "format": "/ C {usage}% ",
    "on-click": "",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Memory
  "memory": {
    "format": "/ M {}% ",
    "on-click": "kitty -e htop",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Harddisc space used
  "disk": {
    "interval": 30,
    "format": "D {percentage_used}% ",
    "path": "/",
    "on-click": "",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  "hyprland/language": {
    "format": "/ K {short}",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Group Hardware
  "group/hardware": {
    "orientation": "inherit",
    "modules": [
      "custom/gpu",
      "disk",
      "cpu",
      "memory"
    ]
  },
  // Group Tools
  "group/tools": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 200,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/tools",
      "custom/cliphist",
      "custom/hypridle",
      "custom/hyprshade",
      "power-profiles-daemon"
    ]
  },
  // Group Links
  "group/links": {
    "orientation": "horizontal",
    "modules": [
      "custom/chatgpt",
      "custom/empty"
    ]
  },
  // Group Settings
  "group/settings": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 200,
      "children-class": "not-memory",
      "transition-left-to-right": true
    },
    "modules": [
      "custom/settings",
      "custom/waybarthemes",
      "custom/wallpaper"
    ]
  },
  // Network
  "custom/ufw": {
    "exec": "~/.config/waybar/scripts/ufw_blocked.sh",
    "interval": 10,
    "return-type": "json",
    "on-click": "kitty -e ~/.config/waybar/scripts/ufw_view.sh"
  },
  "custom/external_ip": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/external_ip.sh",
    "interval": 360
  },
  "custom/est": {
    "interval": 10,
    "exec": "ss -t state established | wc -l",
    "format": "EST {}",
    "on-click": "kitty sh -lc 'cmd=\"ss -t state established -p -n\"; echo \"$cmd\"; echo; eval \"$cmd\"; echo; read -n1 -s -r -p \"Press any key to close\"'"
  },
  "network": {
    "format": "{ifname}",
    "format-wifi": "яЗл  {signalStrength}%",
    "format-ethernet": "яЮЦ  {ifname}",
    "format-disconnected": "Disconnected тЪа",
    "tooltip-format": "яЮЦ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "яЗл  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "яЮЦ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "",
    "on-click-right": "",
  },
  "custom/clamav": {
    "exec": "~/.config/waybar/scripts/clamav_status.sh",
    "interval": 1200,
    "format": "ClamAV {}",
    "tooltip": false
  },
  // Group Network
  "group/network": {
    "orientation": "inherit",
    "modules": [
      "network",
      "custom/external_ip",
      "custom/est",
      "custom/ufw",
      "custom/clamav"
    ]
  },
  // Battery
  "battery": {
    "interval": 1,
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "яЧз  {capacity}%",
    "format-plugged": "яЗж  {capacity}%",
    "format-alt": "{icon}  {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": [
      "яЙД ",
      "яЙГ ",
      "яЙВ ",
      "яЙБ ",
      "яЙА "
    ]
  },
  // Power Profiles Daemon
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "яЖЕ",
      "performance": "яГз",
      "balanced": "ябг",
      "power-saver": "яБм"
    },
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  // Pulseaudio
  "pulseaudio": {
    "scroll-step": 1, // %, can be a float
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
    "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
    "format-muted": "яЪй {format_source}",
    "format-source": "{volume}% яД░",
    "format-source-muted": "яД▒",
    "format-icons": {
      "headphone": "яАе ",
      "hands-free": "яЦР ",
      "headset": "яЦР ",
      "phone": "яВХ ",
      "portable": "яВХ ",
      "car": "яЖ╣ ",
      "default": [
        "яАж",
        "яАи",
        "яАи"
      ]
    },
    "on-click": "pavucontrol"
  },
  // Bluetooth
  "bluetooth": {
    "format": "яКУ {status}",
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "sleep 0.1 && ~/.config/ml4w/settings/bluetooth.sh",
    "tooltip-format-connected": "Connected devices: {num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t| Battery life: {device_battery_percentage}%",
    "format-no-controller": ""
  },
  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },
  // backlight:
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "юОН",
      "юПФ",
      "юПУ",
      "юПТ",
      "юПС",
      "юПР",
      "юПП",
      "юПО",
      "юПН",
      "юПМ",
      "юПЛ",
      "юПК",
      "юПЙ",
      "юПИ",
      "юОЫ"
    ],
    "scroll-step": 1
  }
}
