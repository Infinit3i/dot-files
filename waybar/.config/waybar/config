{
  "include": [
    "~/.dotfiles/waybar/.config/waybar/modules.json"
  ],
  "position": "top",
  "layer": "top",
  "height": 46,
  "margin-top": 1,
  "margin-bottom": 0,
  "margin-left": 0,
  "margin-right": 0,
  "modules-left": [
    "hyprland/window",
    "custom/updates",
    "custom/weather"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "custom/streamer",
    "group/network",
    "cpu",
    "custom/gpu",
    "memory",
    "disk",
    "pulseaudio",
    "group/tools",
    "custom/clock",
    "custom/power"
  ],
  "custom/weather": {
    "format": "{text}",
    "return-type": "json",
    "interval": 300,
    "exec": "bash ~/.config/waybar/scripts/weather.sh",
    "exec-if": "ping -c1 -W1 wttr.in >/dev/null 2>&1",
    "on-click": "xdg-open 'https://wttr.in/'"
  },
  "custom/spotify": {
    "interval": 2,
    "return-type": "json",
    "exec": "bash -lc 's=$(playerctl --player=spotify metadata --format \"{{artist}} - {{title}}\" 2>/dev/null); if [ -n \"$s\" ]; then printf \"{\\\"text\\\":\\\"\\\",\\\"tooltip\\\":\\\"%s\\\"}\" \"${s//\\\"/\\\\\\\"}\"; else printf \"{\\\"text\\\":\\\"\\\",\\\"tooltip\\\":\\\"\\\"}\"; fi'"
  },
  "custom/power": {
    "format": "⏻",
    "on-click": "wlogout",
    "tooltip": false
  }
}