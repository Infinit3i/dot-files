{
  "include": [
    "~/.dotfiles/waybar/.config/waybar/modules.json"
  ],
  "position": "top",
  "layer": "top",
  "height": 16,
  "margin-top": 2,
  "margin-bottom": 0,
  "margin-left": 0,
  "margin-right": 0,
  "modules-left": [
    "custom/rofi",
    "custom/weather",
    "custom/updates",
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "group/network",
    "custom/gpu",
    "group/hardware",
    "custom/spotify",
    "pulseaudio",
    "custom/mako",
    "clock",
    "custom/power"
  ],
  "custom/rofi": {
    "format": "",
    "tooltip": false,
    "on-click": "rofi -show drun",
    "on-click-middle": "pkill -9 rofi"
  },
  "custom/weather": {
    "format": "{text}",
    "return-type": "json",
    "interval": 120,
    "exec": "bash ~/.config/waybar/scripts/weather.sh",
    "exec-if": "ping -c1 -W1 wttr.in >/dev/null 2>&1",
    "on-click": "xdg-open 'https://wttr.in/'"
  },
  "custom/gpu": {
    "format": "GPU {}",
    "exec": "~/.config/waybar/scripts/gpu_util.sh",
    "interval": 2,
    "return-type": "json"
  },
  "custom/mako": {
    "format": "🔔 {}",
    "exec": "~/.config/waybar/scripts/mako_dnd.sh",
    "interval": 1,
    "on-click": "makoctl mode -t do-not-disturb"
  },
  "custom/spotify": {
    "interval": 5,
    "exec": "playerctl --player=spotify metadata --format '{{artist}} - {{title}}' 2>/dev/null || echo ''",
    "format": "{} ",
    "max-length": 40,
    "on-click": "playerctl --player=spotify play-pause",
    "on-scroll-up": "playerctl --player=spotify next",
    "on-scroll-down": "playerctl --player=spotify previous",
    "on-click-right": "kitty sh -lc 'cmd=\"playerctl --player=spotify metadata --format \\\"{{artist}} - {{title}}\\\"\"; echo \"$cmd\"; echo; eval \"$cmd\"; echo; read -n1 -s -r -p \"Press any key to close\"'"
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-muted": " muted",
    "format-icons": {
      "default": [
        "",
        "",
        ""
      ]
    },
    "scroll-step": 1,
    "on-click": "pavucontrol",
    "on-click-right": ""
  },
  "custom/power": {
    "format": "⏻",
    "on-click": "wlogout",
    "tooltip": false
  }
}